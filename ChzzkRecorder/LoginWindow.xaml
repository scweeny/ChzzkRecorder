<Window x:Class="ChzzkRecorder.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChzzkRecorder"
        mc:Ignorable="d"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="네이버 로그인" Height="700" Width="500"
        WindowStartupLocation="CenterOwner" Loaded="Window_Loaded">
    <Grid>
        <!-- WebView2 브라우저 컨트롤 -->
        <wv2:WebView2 x:Name="webView" />

        <TextBlock x:Name="TxtLoading" Text="로딩 중..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Visibility="Collapsed"/>
    </Grid>
</Window>
