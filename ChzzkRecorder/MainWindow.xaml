<Window x:Class="ChzzkRecorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:ChzzkRecorder"
        mc:Ignorable="d"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="CHZ Recorder - 치지직 녹화 및 다운로더" Height="800" Width="1100" 
        Background="#F5F5F7" FontFamily="Segoe UI, Malgun Gothic" FontSize="14"
        WindowStartupLocation="CenterScreen" Initialized="Window_Initialized" Closing="Window_Closing">
    <!-- Window Resources: 전역 스타일 정의 (치지직 녹색 포인트) -->
    <Window.Resources>
        <SolidColorBrush x:Key="ChzzkGreen" Color="#00FFA3"/>
        <SolidColorBrush x:Key="ChzzkDarkGreen" Color="#00C781"/>

        <!-- [수정완료] 탭 헤더 스타일 정의 (TargetType 제거) -->
        <Style x:Key="ChzzkTabItemStyle">
            <Setter Property="TabItem.HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{TemplateBinding Content}" FontSize="16" FontWeight="SemiBold" Padding="15,7"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="TabItem.Background" Value="Transparent"/>
            <Setter Property="TabItem.BorderThickness" Value="0,0,0,2"/>
            <Setter Property="TabItem.BorderBrush" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="TabItem.IsSelected" Value="True">
                    <Setter Property="TabItem.Foreground" Value="Black"/>
                    <Setter Property="TabItem.BorderBrush" Value="{StaticResource ChzzkDarkGreen}"/>
                </Trigger>
                <Trigger Property="TabItem.IsSelected" Value="False">
                    <Setter Property="TabItem.Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- [수정완료] 기본 버튼 스타일 (TargetType 제거) -->
        <Style x:Key="DefaultButtonStyle">
            <Setter Property="Button.Background" Value="White"/>
            <Setter Property="Button.BorderBrush" Value="#DCDCDC"/>
            <Setter Property="Button.BorderThickness" Value="1"/>
            <Setter Property="Button.Padding" Value="15,8"/>
            <Setter Property="Button.Margin" Value="0,0,10,0"/>
            <Setter Property="Button.Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="Button.IsMouseOver" Value="True">
                    <Setter Property="Button.Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 강조 버튼 스타일 (녹색) -->
        <Style x:Key="AccentButtonStyle" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Button.Background" Value="{StaticResource ChzzkGreen}"/>
            <Setter Property="Button.Foreground" Value="Black"/>
            <Setter Property="Button.FontWeight" Value="Bold"/>
            <Setter Property="Button.BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="Button.IsMouseOver" Value="True">
                    <Setter Property="Button.Background" Value="{StaticResource ChzzkDarkGreen}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 위험 버튼 스타일 (빨강) -->
        <Style x:Key="DangerButtonStyle" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Button.Background" Value="#FF4D4D"/>
            <Setter Property="Button.Foreground" Value="White"/>
            <Setter Property="Button.FontWeight" Value="Bold"/>
            <Setter Property="Button.BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="Button.IsMouseOver" Value="True">
                    <Setter Property="Button.Background" Value="#FF3333"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    

    <Grid>    
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Main Menu/Tabs -->
            <RowDefinition Height="*"/>
            <!-- Content Area -->
            <RowDefinition Height="Auto"/>
            <!-- Status Bar -->
        </Grid.RowDefinitions>

        <tb:TaskbarIcon x:Name="MyNotifyIcon" IconSource="/icon.ico" ToolTipText="CHZ Recorder (백그라운드 실행 중)" TrayMouseDoubleClick="MyNotifyIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <!-- 우클릭 컨텍스트 메뉴 디자인 -->
                <ContextMenu>
                    <MenuItem Header="프로그램 다시 열기" Click="MenuOpen_Click" FontWeight="Bold">
                        <MenuItem.Icon>
                            <iconPacks:PackIconMaterial Kind="WindowMaximize" Foreground="#00C781"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="종료 (완전 종료)" Click="MenuExit_Click">
                        <MenuItem.Icon>
                            <iconPacks:PackIconMaterial Kind="ExitToApp" Foreground="#FF4D4D"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- 1. 메인 탭 컨트롤 (상단) -->
        <!-- [수정완료] TabItemStyle을 Window.Resources에 정의된 스타일로 바인딩 -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="10"
                    ItemContainerStyle="{StaticResource ChzzkTabItemStyle}">

            <!-- ============================================================================== -->
            <!-- 탭 1: 생방송 녹화 -->
            <!-- ============================================================================== -->
            <TabItem Header="생방송 녹화">
                <Grid Background="White" Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Toolbar -->
                        <RowDefinition Height="*"/>
                        <!-- Grid -->
                        <RowDefinition Height="Auto"/>
                        <!-- 화면 분할선 -->
                        <RowDefinition Height="200"/>
                        <!-- 로그 뷰어 -->
                    </Grid.RowDefinitions>

                    <!-- 도구 모음 -->
                    <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="10">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource DefaultButtonStyle}" Name="btn_Record_AddStremaer" Click="btn_Record_AddStremaer_Click">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Plus" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="스트리머 추가"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource DefaultButtonStyle}" Click="BtnEditStreamer_Click">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Pencil" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="선택 수정"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnDeleteStreamer" Style="{StaticResource DefaultButtonStyle}" Click="BtnDeleteStreamer_Click">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Delete" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="선택 삭제"/>
                                </StackPanel>
                            </Button>
                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0,15,0"/>
                            <Button x:Name="BtnStartSelected" Style="{StaticResource AccentButtonStyle}" Click="BtnStartSelected_Click">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Play" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="선택 녹화 시작"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnStopSelected" Style="{StaticResource DangerButtonStyle}" Click="BtnStopSelected_Click">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Stop" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="선택 중지"/>
                                </StackPanel>
                            </Button>
                            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5,0,15,0"/>
                            <Button x:Name="BtnStartAll" Style="{StaticResource AccentButtonStyle}" Click="BtnStartAll_Click">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Play" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="전체 녹화 시작"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnStopAll" Style="{StaticResource DangerButtonStyle}" Click="BtnStopAll_Click">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Stop" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="전체 중지"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- 스트리머 목록 그릿드 -->
                    <DataGrid x:Name="StreamerDataGrid" Grid.Row="1" Margin="10" AutoGenerateColumns="False" CanUserAddRows="False" 
                              Background="White" RowHeight="40" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
                              BorderThickness="1" BorderBrush="#DCDCDC">

                        <DataGrid.Resources>
                            <Style x:Key="CenterText" TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0,10,0"/>
                                <!-- 텍스트가 선에 너무 붙지 않게 좌우 여백 10 추가 -->
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <!-- 상태 컬럼 (예시 아이콘) -->
                            <DataGridTemplateColumn Header="상태" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="12" Height="12" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <!-- 1. 기본 상태: 대기 중 (회색) -->
                                                    <Setter Property="Fill" Value="#CCCCCC"/>
                                                    <Setter Property="ToolTip" Value="대기 중"/>

                                                    <!-- 2. 조건별 상태 변경 (DataTrigger) -->
                                                    <Style.Triggers>
                                                        <!-- State 값이 "Rec"일 때: 녹화 중 (빨간색) -->
                                                        <DataTrigger Binding="{Binding State}" Value="Rec">
                                                            <Setter Property="Fill" Value="#FF4D4D"/>
                                                            <Setter Property="ToolTip" Value="녹화 중"/>
                                                        </DataTrigger>

                                                        <!-- State 값이 "Error"일 때: 에러 (노란색/주황색) -->
                                                        <DataTrigger Binding="{Binding State}" Value="Error">
                                                            <Setter Property="Fill" Value="#FFC107"/>
                                                            <Setter Property="ToolTip" Value="오류 발생 (로그 확인)"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="스트리머 이름" Binding="{Binding Name}" Width="150" FontWeight="Bold" ElementStyle="{StaticResource CenterText}"/>
                            <DataGridTextColumn Header="현재 방송 제목" Binding="{Binding Title}" Width="*" ElementStyle="{StaticResource CenterText}"/>
                            <DataGridTextColumn Header="시작 시간" Binding="{Binding StartTime}" Width="120" ElementStyle="{StaticResource CenterText}"/>
                            <DataGridTextColumn Header="저장 폴더" Binding="{Binding SavePath}" Width="300" ElementStyle="{StaticResource CenterText}"/>
                        </DataGrid.Columns>                       
                    </DataGrid>
                    <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="#F0F0F0" Cursor="SizeNS"/>
                    <GroupBox Grid.Row="3" Margin="10" Header="실시간 진행 로그 (위 목록에서 스트리머를 선택하세요)">
                        <!-- Text 바인딩을 통해 선택된 항목(SelectedItem)의 Logs 데이터를 가져옵니다 -->
                        <!-- TextChanged 이벤트로 새 로그가 추가될 때마다 자동으로 맨 아래로 스크롤되게 합니다 -->
                        <TextBox IsReadOnly="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 Text="{Binding ElementName=StreamerDataGrid, Path=SelectedItem.Logs, Mode=OneWay}"
                                 Background="#1E1E1E" Foreground="#00FFA3" FontFamily="Consolas" Padding="8" FontSize="13"
                                 TextChanged="LogTextBox_TextChanged"/>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ============================================================================== -->
            <!-- 탭 2: 다시보기 다운로드 -->
            <!-- ============================================================================== -->
            <TabItem Header="다시보기 다운로드">
                <Grid Background="White" Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- URL Input -->
                        <RowDefinition Height="*"/>
                        <!-- Download List -->
                        <RowDefinition Height="Auto"/>
                        <!-- Control Buttons -->
                    </Grid.RowDefinitions>

                    <!-- URL 입력 영역 -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="다시보기(VOD) 링크 입력" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtVodUrl" Padding="10" BorderBrush="#DCDCDC" FontSize="14" VerticalContentAlignment="Center"
                                     ToolTip="https://chzzk.naver.com/video/... 주소를 입력하세요"/>
                            <!-- Watermark 텍스트 (간단 구현) -->
                            <TextBlock Text="https://chzzk.naver.com/video/..." Foreground="#999999" IsHitTestVisible="False" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style>
                                        <Setter Property="TextBlock.Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtVodUrl}" Value="">
                                                <Setter Property="TextBlock.Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Button x:Name="BtnAnalyzeVod" Grid.Column="1" Content="분석하기" Style="{StaticResource AccentButtonStyle}" Margin="10,0,0,0" Padding="20,0" Click="BtnAnalyzeVod_Click"/>
                        </Grid>
                    </StackPanel>

                    <!-- 다운로드 목록 (DataGrid) -->
                    <DataGrid x:Name="VodDataGrid" Grid.Row="1" Margin="0,0,0,15" AutoGenerateColumns="False" CanUserAddRows="False" 
          Background="White" RowHeight="50" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
          BorderThickness="1" BorderBrush="#DCDCDC">

                        <!-- ★ 1. 컬럼 내부 텍스트를 수직 가운데 정렬하기 위한 공통 스타일 -->
                        <DataGrid.Resources>
                            <Style x:Key="CenterText" TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="10,0,10,0"/>
                                <!-- 텍스트가 선에 너무 붙지 않게 좌우 여백 10 추가 -->
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <!-- ★ 2. 텍스트 컬럼들에 ElementStyle="{StaticResource CenterText}" 적용 -->
                            <DataGridTextColumn Header="[날짜] 스트리머 명 - 방송 제목" Binding="{Binding FileName}" Width="*" ElementStyle="{StaticResource CenterText}"/>
                            <DataGridTextColumn Header="해상도" Binding="{Binding Resolution}" Width="120" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTemplateColumn Header="진행률" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <!-- ★ Grid 자체를 수직 중앙 정렬(VerticalAlignment="Center") -->
                                        <Grid Margin="5,0" VerticalAlignment="Center">
                                            <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="20" Foreground="{StaticResource ChzzkGreen}" Background="#E0E0E0" BorderThickness="0"/>
                                            <TextBlock Text="{Binding ProgressText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" Foreground="Black" FontWeight="Bold"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="속도" Binding="{Binding Speed}" Width="100" ElementStyle="{StaticResource CenterText}"/>

                            <DataGridTemplateColumn Header="상태" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <!-- ★ StackPanel 전체를 수직 중앙 정렬 -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <Button Padding="5" Background="Transparent" BorderThickness="0" Margin="0" ToolTip="폴더 열기" Visibility="Collapsed">
                                                <iconPacks:PackIconMaterial Kind="FolderOpen" Foreground="#666666"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 하단 컨트롤 버튼 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="▶ 선택 다운로드 시작" Style="{StaticResource AccentButtonStyle}" Click="BtnStartVodDownload_Click"/>
                        <Button Content="⏸ 일시 정지" Style="{StaticResource DefaultButtonStyle}" Click="BtnPauseVodDownload_Click"/>
                        <Button Content="⬛ 취소/목록 삭제" Style="{StaticResource DangerButtonStyle}" Margin="0" Click="BtnDeleteVod_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ============================================================================== -->
            <!-- 탭 3: 설정 -->
            <!-- ============================================================================== -->
            <TabItem Header="설정">
                <ScrollViewer Margin="0,10,0,0" Background="White" Padding="15" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 설정 세션 스타일 -->
                        <StackPanel.Resources>
                           
                        </StackPanel.Resources>

                        <!-- 1. 네이버 로그인 -->
                        <GroupBox Header="네이버 로그인 설정">
                            <DockPanel>
                                <iconPacks:PackIconMaterial Kind="AccountCircle" Width="40" Height="40" Foreground="#CCCCCC" DockPanel.Dock="Left" Margin="0,0,15,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtLoginStatus" Text="현재 상태: 로그인되어 있지 않음" FontSize="14" FontWeight="Normal" Margin="0,0,0,5"/>
                                    <TextBlock Text="성인 인증 및 구독 전용 방송 녹화/다운로드에 필요합니다." FontSize="12" Foreground="#666666" FontWeight="Normal"/>
                                </StackPanel>
                                <Button x:Name="BtnLogin" Content="로그인 하기" Style="{StaticResource AccentButtonStyle}" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0" Click="BtnLogin_Click"/>
                            </DockPanel>
                        </GroupBox>

                        <!-- 2. 저장 및 파일명 -->
                        <GroupBox Header="녹화 및 다운로드 저장 설정">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Grid.Column="0" Content="기본 저장 폴더"/>
                                <TextBox x:Name="TxtDefaultSaveFolder" Grid.Row="0" Grid.Column="1" Text="" VerticalContentAlignment="Center"  IsReadOnly="True" Background="#F5F5F5"/>
                                <Button x:Name="BtnBrowseDefaultFolder" Grid.Row="0" Grid.Column="2" Content="찾아보기" Style="{StaticResource DefaultButtonStyle}" Margin="10,0,0,0" Click="BtnBrowseDefaultFolder_Click"/>

                                <Label Grid.Row="1" Grid.Column="0" Content="파일명 형식"/>
                                <!-- x:Name="CmbFileNameFormat" 추가 -->
                                <ComboBox x:Name="CmbFileNameFormat" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" SelectedIndex="0" Padding="8,5">
                                    <ComboBoxItem Content="{}{날짜}_{스트리머}_{제목}"/>
                                    <ComboBoxItem Content="{}{스트리머}_{날짜}_{제목}"/>
                                </ComboBox>

                            </Grid>
                        </GroupBox>

                        <!-- 3. 인코더 설정 -->
                        <!-- 3. 생방송 녹화 설정 (이름 변경) -->
                        <GroupBox Header="생방송 녹화 설정">
                            <StackPanel>
                                <!-- 기존 FFmpeg 경로 설정 -->
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Content="FFmpeg 경로"/>
                                    <TextBox x:Name="TxtFfmpegPath" Grid.Column="1" Text="C:\ffmpeg\bin\ffmpeg.exe" VerticalContentAlignment="Center" Padding="8,5"/>
                                    <Button Grid.Column="2" Content="찾아보기" Style="{StaticResource DefaultButtonStyle}" Margin="10,0,0,0"/>
                                    <Button Grid.Column="3" x:Name="BtnDownloadFfmpeg" Content="자동 다운로드" Style="{StaticResource AccentButtonStyle}" Margin="10,0,0,0" Click="BtnDownloadFfmpeg_Click"/>
                                </Grid>

                                <!-- 1. 비디오 코덱 설정 -->
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Content="비디오 코덱"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <!-- ★ [신규] 원본 옵션 추가 -->
                                        <RadioButton x:Name="RdoCodecCopy" Content="원본" IsChecked="True" Margin="0,0,15,0" VerticalAlignment="Center" Checked="Codec_Checked"/>
                                        <RadioButton x:Name="RdoCodecH264" Content="H.264" Margin="0,0,15,0" VerticalAlignment="Center" Checked="Codec_Checked"/>
                                        <RadioButton x:Name="RdoCodecH265" Content="H.265 (HEVC)" Margin="0,0,15,0" VerticalAlignment="Center" Checked="Codec_Checked"/>
                                        <RadioButton x:Name="RdoCodecAV1" Content="AV1" VerticalAlignment="Center" Checked="Codec_Checked"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 2. 인코더 (하드웨어 가속) 설정 (x:Name 추가) -->
                                <Grid x:Name="GridEncoderSelection" Margin="0,0,0,15" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Content="인코더 선택"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" >
                                        <RadioButton x:Name="RdoEncCPU" Content="CPU" IsChecked="True" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <RadioButton x:Name="RdoEncNVENC" Content="Nvidia (NVENC)" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <RadioButton x:Name="RdoEncQSV" Content="Intel (QSV)" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                        <RadioButton x:Name="RdoEncAMF" Content="AMD (AMF)" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 3. 비트레이트 및 용량 계산 (x:Name 추가) -->
                                <Grid x:Name="GridBitrateSelection" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Content="비트레이트"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Border BorderBrush="#DCDCDC" BorderThickness="1" CornerRadius="2" Width="110" Height="34">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="25"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBox x:Name="TxtBitrate" Grid.Column="0" Text="8000" BorderThickness="0" 
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center" 
                                 TextChanged="TxtBitrate_TextChanged" 
                                 PreviewTextInput="TxtBitrate_PreviewTextInput" 
                                 InputMethod.IsInputMethodEnabled="False"/>

                                                <Grid Grid.Column="1">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <RepeatButton Grid.Row="0" Click="BtnBitrateUp_Click" Delay="300" Interval="50"
                                          Background="#F5F5F5" BorderThickness="1,0,0,1" BorderBrush="#DCDCDC" Padding="0">
                                                        <iconPacks:PackIconMaterial Kind="ChevronUp" Width="10" Height="10" Foreground="#555555"/>
                                                    </RepeatButton>
                                                    <RepeatButton Grid.Row="1" Click="BtnBitrateDown_Click" Delay="300" Interval="50"
                                          Background="#F5F5F5" BorderThickness="1,0,0,0" BorderBrush="#DCDCDC" Padding="0">
                                                        <iconPacks:PackIconMaterial Kind="ChevronDown" Width="10" Height="10" Foreground="#555555"/>
                                                    </RepeatButton>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="kbps" VerticalAlignment="Center" Margin="10,0,15,0"/>
                                        <TextBlock x:Name="TxtSizePerSec" Text="(약 1.00 MB/초)" VerticalAlignment="Center" Foreground="#888888"/>
                                    </StackPanel>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Content="방송 감지 주기"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <!-- 숫자 컨트롤 래퍼 -->
                                        <Border BorderBrush="#DCDCDC" BorderThickness="1" CornerRadius="2" Width="110" Height="34">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="25"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- ★ 기본값을 Text="5"로 수정 -->
                                                <TextBox x:Name="TxtCheckInterval" Grid.Column="0" Text="5" BorderThickness="0" 
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center" 
                                 PreviewTextInput="TxtBitrate_PreviewTextInput" 
                                 InputMethod.IsInputMethodEnabled="False"/>

                                                <!-- 상하 조절 버튼 -->
                                                <Grid Grid.Column="1">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <RepeatButton Grid.Row="0" Click="BtnIntervalUp_Click" Delay="300" Interval="50"
                                          Background="#F5F5F5" BorderThickness="1,0,0,1" BorderBrush="#DCDCDC" Padding="0">
                                                        <iconPacks:PackIconMaterial Kind="ChevronUp" Width="10" Height="10" Foreground="#555555"/>
                                                    </RepeatButton>
                                                    <RepeatButton Grid.Row="1" Click="BtnIntervalDown_Click" Delay="300" Interval="50"
                                          Background="#F5F5F5" BorderThickness="1,0,0,0" BorderBrush="#DCDCDC" Padding="0">
                                                        <iconPacks:PackIconMaterial Kind="ChevronDown" Width="10" Height="10" Foreground="#555555"/>
                                                    </RepeatButton>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="초" VerticalAlignment="Center" Margin="10,0,15,0"/>
                                        <TextBlock Text="(오프라인일 때 해당 주기마다 방송 켜짐 여부를 자동 확인합니다)" VerticalAlignment="Center" Foreground="#888888"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="기타 설정">
                            <StackPanel>
                                <CheckBox x:Name="ChkMinimizeToTray" Content="창을 최소화할 때 작업 표시줄에서 숨기고 시스템 트레이로 이동" 
                          IsChecked="False" VerticalAlignment="Center" Margin="5"/>

                                <CheckBox x:Name="ChkRunAtStartup" Content="윈도우 부팅 시 트레이 아이콘 모드로 자동 실행" 
                          IsChecked="False" VerticalAlignment="Center" Margin="5" Click="ChkRunAtStartup_Click"/>

                                <CheckBox x:Name="ChkAutoStartRecording" Content="프로그램 실행 시 등록된 모든 스트리머 자동 감시/녹화 시작" 
                          IsChecked="False" VerticalAlignment="Center" Margin="5"/>
                            </StackPanel>
                            

                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>        
    </Grid>
</Window>
